# === ESSENTIAL FILES ONLY ===
# Include only essential files for the blog

/*
!.gitignore
!README.md
!content/
!.github/

# Exclude development files inside content/
content/.obsidian/

# Development & Build files (EXCLUDE)
.github/*
!.github/workflows/
!.github/workflows/*.yml
node_modules/
!package.json
!package-lock.json
!quartz/
!quartz/**
quartz/.quartz-cache/
!quartz.config.ts
!quartz.layout.ts
!tsconfig.json
tsconfig.tsbuildinfo
public/
docs/

# Obsidian & IDE
.obsidian/
.vscode/
.idea/
.claude/

# Project-specific (EXCLUDE)
Blog/
Settings/
Excalidraw/
CLAUDE.md

# System & Temporary files
.DS_Store
._*
Thumbs.db
*.tmp
*.bak
*.swp
.env*
*.key
secrets/

# Screenshot files (exclude root-level and non-content images)
*.png
*.jpg
*.jpeg
*.gif
!quartz/static/icon.png
!quartz/static/og-image.png
!content/assets/**
content/assets/**/._*
