# === ESSENTIAL FILES ONLY ===
# Include only essential files for the blog

/*
!.gitignore
!README.md
!content/

# Exclude development files inside content/
content/docs/.bkit-memory.json
content/docs/.pdca-status.json
content/.obsidian/
content/docs/.pdca-snapshots/

# Development & Build files (EXCLUDE)
.github/
node_modules/
package.json
package-lock.json
quartz/
quartz.config.ts
quartz.layout.ts
tsconfig.json
tsconfig.tsbuildinfo
public/
docs/

# Obsidian & IDE
.obsidian/
.vscode/
.idea/
.claude/

# Project-specific (EXCLUDE)
Blog/
Settings/
Excalidraw/
assets/
CLAUDE.md

# System & Temporary files
.DS_Store
._*
Thumbs.db
*.tmp
*.bak
*.swp
.env*
*.key
secrets/

# Screenshot files
*.png
*.jpg
*.jpeg
*.gif
